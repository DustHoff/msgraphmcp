# Required
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_TENANT_ID=your-tenant-id

# Optional – used when the app registration is a confidential client
AZURE_CLIENT_SECRET=your-client-secret

# Scopes requested during device code flow (space-separated)
# Default includes all scopes including Intune. Override to restrict:
# GRAPH_SCOPES=User.Read Mail.ReadWrite Mail.Send Calendars.ReadWrite Files.ReadWrite.All \
#   Group.ReadWrite.All Team.ReadWrite.All Channel.ReadWrite.All \
#   Sites.ReadWrite.All Tasks.ReadWrite Contacts.ReadWrite \
#   DeviceManagementApps.ReadWrite.All \
#   DeviceManagementConfiguration.ReadWrite.All \
#   DeviceManagementManagedDevices.ReadWrite.All \
#   DeviceManagementServiceConfig.ReadWrite.All \
#   Directory.ReadWrite.All offline_access

# Path inside the container where the MSAL token cache is stored
# TOKEN_CACHE_PATH=/data/tokens.json
